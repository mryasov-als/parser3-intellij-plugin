# ---------------------------------------------------------------------------
# ТЕСТОВЫЕ СЛУЧАИ ДЛЯ FOLDING (СВОРАЧИВАНИЕ КОДА)
# ---------------------------------------------------------------------------
# Формат: каждый блок должен сворачиваться от открывающей до закрывающей скобки
# Ожидаемые folding regions помечены комментариями: # FOLD: start-end

# ---------------------------------------------------------------------------
# 1. ОПРЕДЕЛЕНИЯ МЕТОДОВ
# ---------------------------------------------------------------------------

# 1.1 Простой метод с телом
# FOLD: @simple_method[] до конца тела
@simple_method[]
это тело метода
которое занимает
несколько строк

# 1.2 Метод с параметрами
@method_with_params[param1;param2]
тело метода
с параметрами

# 1.3 Метод с локальными переменными
@method_with_locals[param][local1;local2]
тело метода
с локальными переменными

# ---------------------------------------------------------------------------
# 2. БЛОЧНЫЕ КОММЕНТАРИИ ^rem{}
# ---------------------------------------------------------------------------

# 2.1 Однострочный ^rem (не должен сворачиваться)
^rem{короткий комментарий}

# 2.2 Многострочный ^rem
^rem{
	Это многострочный
	блочный комментарий
	который должен сворачиваться
}

просто текст {
	test
}


<ul>
	<li>^data.foreach[;v]{

	}</li>
</ul>

# 2.3 Вложенные скобки в ^rem
^rem{
	уровень 1 {
		^if(def $data){

		}
		уровень 2 {
			уровень 3
		}
		^rem_method[
			xxx
		]
		^rem_method(
			1
			&&
			2
		)
	}
}

# ---------------------------------------------------------------------------
# 3. УСЛОВНЫЕ КОНСТРУКЦИИ ^if
# ---------------------------------------------------------------------------

# 3.1 Простой ^if с одним блоком
^if($condition){
	тело условия
	на несколько строк
}

# 3.2 ^if с else
^if($a){
	true ветка
}{
	false ветка
}

# 3.3 ^if с else-if
^if($a){
	первое условие
}($b){
	второе условие
}($c){
	третье условие
}{
	иначе
}

# 3.4 Вложенные ^if
^if($outer){
	^if($inner){
		вложенное условие
	}{
		вложенный else
	}
}

# ---------------------------------------------------------------------------
# 4. ЦИКЛЫ
# ---------------------------------------------------------------------------

# 4.1 ^while
^while($i < 10){
	тело цикла while
	$i[^i.inc[]]
}

# 4.2 ^for
^for[i](1;100){
	тело цикла for
	итерация $i
}

# 4.3 ^foreach (на таблице)
^data.foreach[key;value]{
	обработка $key = $value
	многострочная
}

# 4.4 Вложенные циклы
^for[i](1;10){
	^for[j](1;10){
		вложенный цикл
		$i x $j
	}
}

# ---------------------------------------------------------------------------
# 5. SWITCH/CASE
# ---------------------------------------------------------------------------

# 5.1 Простой switch
^switch[$var]{
	^case[a]{
		случай A
	}
	^case[b]{
		случай B
	}
	^case[DEFAULT]{
		по умолчанию
	}
}

# 5.2 Switch с многострочными case
^switch[$type]{
	^case[user]{
		обработка пользователя
		много логики
		на несколько строк
	}
	^case[admin]{
		обработка админа
		тоже много
		логики
	}
}

# ---------------------------------------------------------------------------
# 6. TRY/CATCH
# ---------------------------------------------------------------------------

# 6.1 Простой try
^try{
	опасный код
	который может
	выбросить исключение
}{
	обработка ошибки
	$exception.type
}

# 6.2 Вложенный try
^try{
	^try{
		вложенный опасный код
	}{
		внутренняя обработка
	}
}{
	внешняя обработка
}

# ---------------------------------------------------------------------------
# 7. SQL БЛОКИ
# ---------------------------------------------------------------------------

# 7.1 Простой SQL
^void:sql{
	SELECT *
	FROM users
	WHERE active = 1
}

# 7.2 SQL с конструктором
$users[^table::sql{
	SELECT
		id,
		name,
		email
	FROM
		users
	WHERE
		status = 'active'
	ORDER BY
		name
}]

# 7.3 SQL с вложенными конструкциями
^void:sql{
	UPDATE users
	SET
	^if($name){
			name = '$name',
	}
		^if($email){
			email = '$email',
	}
		updated_at = NOW()
	WHERE id = $id
}

# 7.4 Вложенный SQL
$result[^table::sql{
	SELECT * FROM users
	WHERE id IN (
			^int:sql{
			SELECT user_id
			FROM permissions
			WHERE role = 'admin'
		}
	)
}]

# ---------------------------------------------------------------------------
# 8. ХЕШИ И СТРУКТУРЫ ДАННЫХ
# ---------------------------------------------------------------------------

# 8.1 Создание хеша
$config[^hash::create[
	$.host[localhost]
	$.port[3306]
	$.user[root]
	$.testdata[sample]
]]

# 8.2 Вложенные хеши
$data[^hash::create[
	$.database[^hash::create[
		$.host[localhost]
		$.port[3306]
	]]
	$.cache[^hash::create[
		$.enabled[true]
		$.ttl[3600]
	]]
]]

# 8.3 Хеш с условиями внутри
$options[^hash::create[
	$.debug[$DEBUG]
	$.mode[
		^if($production){
			production
		}{
			development
		}
	]
]]

$data[
	$.var1[
		x
	]
]

# ---------------------------------------------------------------------------
# 9. ВЫЗОВЫ МЕТОДОВ С ТЕЛАМИ
# ---------------------------------------------------------------------------

# 9.1 ^process
^process{
	текст для обработки
	с несколькими строками
	и $переменными
}

# 9.2 ^cache
^cache[3600]{
	кешируемый контент
	дорогие вычисления
	на несколько строк
}

# 9.3 ^connect
^connect[$db]{
	^void:sql{
		INSERT INTO logs
		SET message = 'connected'
	}
}

# 9.4 Цепочка вызовов с телами
^string:trim[
	^string:upper[
		текст для обработки
	]
]

# ---------------------------------------------------------------------------
# 10. КОМБИНИРОВАННЫЕ СЛУЧАИ
# ---------------------------------------------------------------------------

# 10.1 Метод со сложной логикой
@complex_method[data]
^if(def $data){
	^try{
		^connect[$db]{
			^void:sql{
				INSERT INTO data
				SET value = '$data'
			}
		}
	}{
		^log[error: $exception.comment]
	}
}{
	^throw[no data]
}

# 10.2 Вложенные структуры разных типов
^if($show_form){
	<form>
		^for[i](1;$fields_count){
			<div class="field">
				^switch[$fields.$i.type]{
					^case[text]{
						<input type="text" name="field_$i">
					}
					^case[select]{
						<select name="field_$i">
							^options.foreach[k;v]{
								<option value="$k">$v</option>
							}
						</select>
					}
				}
			</div>
		}
	</form>
}

# ---------------------------------------------------------------------------
# 11. ГРАНИЧНЫЕ СЛУЧАИ
# ---------------------------------------------------------------------------

# 11.1 Пустые блоки (не должны сворачиваться или минимальный fold)
^if($a){}
^if($b){}{else}

# 11.2 Однострочные блоки (не должны сворачиваться)
^if($a){короткое тело}
^for[i](1;10){$i}

# 11.3 Блок на двух строках (граничный случай)
^if($a){
}

# 11.4 Экранированные скобки (не влияют на folding)
^if($a){
	текст с ^{ экранированными ^} скобками
}

# 11.5 Скобки в строках (не влияют на folding)
^if($a){
	$text[строка с { фигурными } скобками]
}

# ---------------------------------------------------------------------------
# 12. ДИРЕКТИВЫ (folding для @USE, @CLASS и т.д.)
# ---------------------------------------------------------------------------

# 12.1 @USE с несколькими путями
@USE
/path/to/file1.p
/path/to/file2.p
/path/to/file3.p
relative/path.p

# 12.2 @OPTIONS
@OPTIONS
locals
partial

# ---------------------------------------------------------------------------
# 13. РЕАЛЬНЫЕ ПРИМЕРЫ
# ---------------------------------------------------------------------------

# 13.1 Типичный обработчик формы
@process_form[]
^if(def $form:submit){
	^try{
		$data[^hash::create[
			$.name[^form:name.trim[]]
			$.email[^form:email.trim[]]
			$.message[^form:message.trim[]]
		]]

		^if($data.name && $data.email){
			^connect[$MAIN:db]{
				^void:sql{
					INSERT INTO messages
					SET
						name = '$data.name',
						email = '$data.email',
						message = '$data.message',
						created_at = NOW()
				}
			}
			$result[success]
		}{
			$result[error: empty fields]
		}
	}{
		$result[error: $exception.comment]
	}
}{
	$result[]
}

# 13.2 Генератор HTML таблицы
@render_table[data;columns]
<table class="data-table">
	<thead>
		<tr>
			^columns.foreach[;col]{
				<th>$col.title</th>
			}
		</tr>
	</thead>
	<tbody>
		^data.foreach[;row]{
			<tr>
				^columns.foreach[;col]{
					<td>
						^switch[$col.type]{
							^case[date]{
								^row.[$col.field].format[%d.%m.%Y]
							}
							^case[money]{
								^row.[$col.field].format[%.2f] руб.
							}
							^case[DEFAULT]{
								$row.[$col.field]
							}
						}
					</td>
				}
			</tr>
		}
	</tbody>
</table>

^method(
	1
	&&
	2
)
